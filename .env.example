# Copy this file to .env and fill in real values before running
# `docker compose up -d --build` on your VDS.

# Postgres password for the bundled database container.
POSTGRES_PASSWORD=change-me

# Random long string used to sign sessions. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=change-me

# Your Stripe secret key (starts with sk_live_ or sk_test_).
# Leave empty to run the site without real payments -- checkout will show
# "not available for purchase yet" until this is set.
STRIPE_SECRET_KEY=

# Your Stripe webhook signing secret (starts with whsec_), from the
# webhook endpoint you create in the Stripe dashboard pointing at
# https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Public URL the site is reachable at, used to register the Stripe webhook
# automatically and to build checkout redirect URLs. Include the scheme.
PUBLIC_BASE_URL=http://your-server-ip

# Port exposed on the host for the web (nginx) container.
WEB_PORT=80
