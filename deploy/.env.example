# ДПС Радар — настройки для VDS
# Скопируйте в .env и заполните значения

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Придумайте надёжный пароль (минимум 16 символов)
POSTGRES_PASSWORD=замените_на_надёжный_пароль

# ─── Telegram бот ───────────────────────────────────────────────────────────
# Токен от @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=1234567890:AAF...

# ─── Ваш домен ──────────────────────────────────────────────────────────────
# Бот автоматически зарегистрирует webhook на этот адрес при старте
# ОБЯЗАТЕЛЬНО HTTPS, без слэша в конце
PUBLIC_BASE_URL=https://dps.ваш-домен.ru

# ─── Сессия ─────────────────────────────────────────────────────────────────
# Случайная строка, минимум 32 символа
SESSION_SECRET=замените_на_случайную_строку_минимум_32_символа
