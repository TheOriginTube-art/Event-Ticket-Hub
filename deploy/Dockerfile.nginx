# ============================================================
# Dockerfile.nginx — сборка фронтенда (Vite) + nginx
# Раздаёт статику Mini App и проксирует /api/ на бэкенд
# ============================================================
FROM node:20-alpine AS builder

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

WORKDIR /app

# Манифесты для кэширования слоёв
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

COPY lib/db/package.json                    lib/db/
COPY lib/api-spec/package.json              lib/api-spec/
COPY lib/api-client-react/package.json      lib/api-client-react/
COPY artifacts/dps-radar/package.json       artifacts/dps-radar/

RUN pnpm install --frozen-lockfile

# Исходники
COPY lib/                   lib/
COPY artifacts/dps-radar/   artifacts/dps-radar/

# Собираем фронтенд
# PORT нужен vite.config.ts только для dev-сервера, при build не используется
# BASE_PATH=/ — мини-приложение живёт в корне домена на VDS
ENV PORT=3001
ENV BASE_PATH=/
ENV NODE_ENV=production

RUN pnpm --filter @workspace/db              run build || true
RUN pnpm --filter @workspace/api-spec        run build || true
RUN pnpm --filter @workspace/api-client-react run build || true
RUN pnpm --filter @workspace/dps-radar       run build

# ---- Runtime: nginx ----
FROM nginx:1.27-alpine

# Статика мини-приложения
COPY --from=builder /app/artifacts/dps-radar/dist/public /usr/share/nginx/html

# Конфиг nginx (проксирует /api/ на бэкенд)
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
