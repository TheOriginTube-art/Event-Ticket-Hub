# Standalone Docker build for the TicketFlow frontend (self-hosted, no Replit).
# Build from the repo root: docker build -f Dockerfile.web -t ticketflow-web .

FROM node:22-slim AS build
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

COPY . .
ENV CI=true
RUN pnpm install --frozen-lockfile

# vite.config.ts requires these at build time; the value doesn't matter for
# the build step itself since assets are served with an absolute base path.
ENV PORT=5173
ENV BASE_PATH=/

RUN pnpm --filter @workspace/ticketflow run build

FROM nginx:1.27-alpine AS runtime
COPY --from=build /repo/artifacts/ticketflow/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
