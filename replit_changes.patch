diff --git a/.github/workflows/healthcheck.yml b/.github/workflows/healthcheck.yml
new file mode 100644
index 0000000..46bf5c1
--- /dev/null
+++ b/.github/workflows/healthcheck.yml
@@ -0,0 +1,44 @@
+name: Post-deploy health check
+
+on:
+  push:
+    branches: [main]
+  workflow_dispatch:
+
+jobs:
+  healthcheck:
+    name: Health check
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Wait for server to settle
+        run: sleep 10
+
+      - name: Run health check
+        id: check
+        env:
+          PUBLIC_BASE_URL: ${{ secrets.PUBLIC_BASE_URL }}
+          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
+          # Allow fewer retries in CI — the server is already running
+          HEALTHCHECK_RETRIES: 6
+          HEALTHCHECK_RETRY_DELAY: 10
+        run: bash deploy/healthcheck.sh
+        continue-on-error: true   # capture exit code; Telegram step runs either way
+
+      - name: Notify Telegram on failure
+        if: steps.check.outcome == 'failure' && env.TELEGRAM_BOT_TOKEN != ''
+        env:
+          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
+          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_ALERT_CHAT_ID }}
+        run: |
+          HOST="${{ github.repository }} @ ${{ github.sha }}"
+          MSG="🚨 Health check FAILED after push to main%0A${HOST}%0A%0ACheck the Actions log:%0A${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}"
+          curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
+            --data "chat_id=${TELEGRAM_CHAT_ID}&text=${MSG}" > /dev/null
+
+      - name: Fail the workflow if health check failed
+        if: steps.check.outcome == 'failure'
+        run: exit 1
